# Supabase — copy to .env for local tooling or CI (never commit .env).
# Dashboard: https://supabase.com/dashboard → your project → Settings → API
#
# Used by bundlers / Node scripts. For static HTML + ES modules, prefer
# js/supabase.config.js (see js/supabase.config.example.js).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
